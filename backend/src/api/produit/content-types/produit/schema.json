{
  "kind": "collectionType",
  "collectionName": "produits",
  "info": {
    "singularName": "produit",
    "pluralName": "produits",
    "displayName": "Produit"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nom": {
      "type": "string",
      "minLength": 2,
      "required": true
    },
    "prix": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "en_stock": {
      "type": "integer",
      "required": true,
      "min": 0
    },
    "categorie": {
      "type": "string"
    },
    "type": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Produit Fini",
        "Matière Première"
      ]
    },
    "ligne_commandes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::ligne-commande.ligne-commande",
      "mappedBy": "produit"
    }
  }
}
